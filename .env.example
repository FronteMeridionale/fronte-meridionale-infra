# Fronte Meridionale — Environment Variables
# Copy this file to .env.local and fill in the values.

# ── Next.js App ─────────────────────────────────────────────────────────────

NODE_ENV=production

# Full public URL of the web service (no trailing slash)
# On Render: https://<your-service-name>.onrender.com
NEXT_PUBLIC_API_URL=https://fronte-meridionale-app.onrender.com

# SQLite database file path (must be on a Render Persistent Disk)
# Render disk is mounted at /var/data — keep this path in sync with render.yaml
DATABASE_PATH=/var/data/members.db

# Telegram Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# ── Telegram Bot (Background Worker) ────────────────────────────────────────

# Base URL of the web service — used by the bot to call the REST API
# On Render: same value as NEXT_PUBLIC_API_URL
BACKEND_URL=https://fronte-meridionale-app.onrender.com
